\@writefile{lot}{\contentsline {table}{\numberline {S2}{\ignorespaces \textbf  {d$_S$ permutation test}: Permutation test results for all pairwise species comparisons. Measured dS$_A$-dS$_X$, and estimated dS$_A$-dS$_X$ calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted dS$_A$-dS$_X$ values.\relax }}{}{table.caption.25}\protected@file@percent }
\newlabel{SItab:BUSCO}{{S2}{}{\textbf {d$_S$ permutation test}: Permutation test results for all pairwise species comparisons. Measured dS$_A$-dS$_X$, and estimated dS$_A$-dS$_X$ calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted dS$_A$-dS$_X$ values.\relax }{table.caption.25}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S3}{\ignorespaces \textbf  {d$_N$/d$_S$ permutation test}: Permutation test results for all pairwise species comparisons. Measured dN$_A$/dS$_A$-dN$_X$/dS$_X$, and estimated dN$_A$/dS$_A$-dN$_X$/dS$_X$ calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted dN$_A$/dS$_A$-dN$_X$/dS$_X$ values.\relax }}{}{table.caption.26}\protected@file@percent }
\newlabel{SItab:BUSCO}{{S3}{}{\textbf {d$_N$/d$_S$ permutation test}: Permutation test results for all pairwise species comparisons. Measured dN$_A$/dS$_A$-dN$_X$/dS$_X$, and estimated dN$_A$/dS$_A$-dN$_X$/dS$_X$ calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted dN$_A$/dS$_A$-dN$_X$/dS$_X$ values.\relax }{table.caption.26}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S4}{\ignorespaces \textbf  {Positive selection permutation test}: Permutation test results for all pairwise species comparisons. Measured and estimated difference in proportion (diff. prop.) of positively selected genes on autosomes vs. X, calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted values.\relax }}{}{table.caption.27}\protected@file@percent }
\newlabel{SItab:BUSCO}{{S4}{}{\textbf {Positive selection permutation test}: Permutation test results for all pairwise species comparisons. Measured and estimated difference in proportion (diff. prop.) of positively selected genes on autosomes vs. X, calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted values.\relax }{table.caption.27}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S5}{\ignorespaces Gene age categories of \textit  {C. maculatus} orthologs in the X chromosome and the autosomes. Percentages and absolute counts of genes in each ortholog age category are shown for pairwise comparisons between \textit  {C. maculatus} and \textit  {C. chinensis}, \textit  {B. siliquastri}, and \textit  {A. obtectus}. Age categories are defined relative to \textit  {C. maculatus} orthologs. Because evolutionary distance is measured from the \textit  {C. maculatus} lineage, the minimum detectable age category differs among comparisons, with \textit  {B. siliquastri} and \textit  {A. obtectus} comparisons starting at categories 1 and 2, respectively.\relax }}{}{table.caption.29}\protected@file@percent }
\newlabel{SItab:conservation}{{S5}{}{Gene age categories of \textit {C. maculatus} orthologs in the X chromosome and the autosomes. Percentages and absolute counts of genes in each ortholog age category are shown for pairwise comparisons between \textit {C. maculatus} and \textit {C. chinensis}, \textit {B. siliquastri}, and \textit {A. obtectus}. Age categories are defined relative to \textit {C. maculatus} orthologs. Because evolutionary distance is measured from the \textit {C. maculatus} lineage, the minimum detectable age category differs among comparisons, with \textit {B. siliquastri} and \textit {A. obtectus} comparisons starting at categories 1 and 2, respectively.\relax }{table.caption.29}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S6}{\ignorespaces Median regression results for the model \texttt  {dNdS $\sim $ chromosome + gene age}. The intercept corresponds to autosomal genes in the youngest gene-age category (age=1).\relax }}{}{table.caption.31}\protected@file@percent }
\newlabel{SItab:conservation}{{S6}{}{Median regression results for the model \texttt {dNdS $\sim $ chromosome + gene age}. The intercept corresponds to autosomal genes in the youngest gene-age category (age=1).\relax }{table.caption.31}{}}
