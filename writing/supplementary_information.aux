\@writefile{lof}{\contentsline {figure}{\numberline {S9}{\ignorespaces \textbf  {d$_S$ vs. d$_N$ scatterplots and violin plots of d$_S$ values from X-linked and autosomal orthologs.} Pairwise comparisons between members of three lineages with violin plots of d$_S$ values for X-linked and autosomal 1-to-1 orthologs, and scatterplots of d$_S$ vs. d$_N$. For permutation tests see Table S2.\relax }}{}{figure.caption.23}\protected@file@percent }
\newlabel{dS_plots}{{S9}{}{\textbf {d$_S$ vs. d$_N$ scatterplots and violin plots of d$_S$ values from X-linked and autosomal orthologs.} Pairwise comparisons between members of three lineages with violin plots of d$_S$ values for X-linked and autosomal 1-to-1 orthologs, and scatterplots of d$_S$ vs. d$_N$. For permutation tests see Table S2.\relax }{figure.caption.23}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S2}{\ignorespaces Permutation test results for all pairwise species comparisons. Estimated dS$_A$-dS$_X$ calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted dS$_A$-dS$_X$ values.\relax }}{}{table.caption.25}\protected@file@percent }
\newlabel{SItab:BUSCO}{{S2}{}{Permutation test results for all pairwise species comparisons. Estimated dS$_A$-dS$_X$ calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted dS$_A$-dS$_X$ values.\relax }{table.caption.25}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S10}{\ignorespaces \textbf  {Pairwise comparisons of evolutionary rates between X-linked and autosomal genes.} Violin plots show the distribution of d$_N$/d$_S$ values for X-linked and autosomal 1:1 orthologs in pairwise comparisons within three beetle lineages: Bruchini (\textbf  {A}), Coccinella (\textbf  {B}), and Tribolium (\textbf  {C}). Significance was assessed using permutation tests (10,000 permutations). Histograms show the permutation distribution of differences in mean d$_N$/d$_S$ between autosomal and X-linked genes. The shaded region indicates the 95\% confidence interval under the null distribution, and the vertical pink line marks the observed difference in mean d$_N$/d$_S$ between chromosome classes. In all comparisons, X-linked orthologs show significantly lower d$_N$/d$_S$ values than autosomal orthologs. The within-family comparisons are performed for three species groups: \textit  {Bruchini} (\textbf  {A}), \textit  {Coccinella} (\textbf  {B}) and \textit  {Tribolium} (\textbf  {C}). \relax }}{}{figure.caption.26}\protected@file@percent }
\newlabel{dNdS_ratios}{{S10}{}{\textbf {Pairwise comparisons of evolutionary rates between X-linked and autosomal genes.} Violin plots show the distribution of d$_N$/d$_S$ values for X-linked and autosomal 1:1 orthologs in pairwise comparisons within three beetle lineages: Bruchini (\textbf {A}), Coccinella (\textbf {B}), and Tribolium (\textbf {C}). Significance was assessed using permutation tests (10,000 permutations). Histograms show the permutation distribution of differences in mean d$_N$/d$_S$ between autosomal and X-linked genes. The shaded region indicates the 95\% confidence interval under the null distribution, and the vertical pink line marks the observed difference in mean d$_N$/d$_S$ between chromosome classes. In all comparisons, X-linked orthologs show significantly lower d$_N$/d$_S$ values than autosomal orthologs. The within-family comparisons are performed for three species groups: \textit {Bruchini} (\textbf {A}), \textit {Coccinella} (\textbf {B}) and \textit {Tribolium} (\textbf {C}). \relax }{figure.caption.26}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S11}{\ignorespaces \textbf  {Positive selection in X-linked and autosomal orthologs.} Orthologs were classified as positively selected using likelihood ratio tests comparing PAML site models M1a and M2a. The proportion of genes containing positively selected codons was compared between autosomal and X-linked orthologs. Histograms show the permutation distribution (10,000 permutations) of the difference in the percentage of positively selected genes between chromosome classes. The shaded region indicates the 95\% confidence interval under the null distribution, and the vertical pink line marks the observed difference. Bruchini (\textbf  {A}) shows a significant enrichment of positively selected X-linked orthologs across all pairwise comparisons, whereas Coccinella (\textbf  {B}) and Tribolium (\textbf  {C}) show no significant difference. \relax }}{}{figure.caption.27}\protected@file@percent }
\newlabel{site_models}{{S11}{}{\textbf {Positive selection in X-linked and autosomal orthologs.} Orthologs were classified as positively selected using likelihood ratio tests comparing PAML site models M1a and M2a. The proportion of genes containing positively selected codons was compared between autosomal and X-linked orthologs. Histograms show the permutation distribution (10,000 permutations) of the difference in the percentage of positively selected genes between chromosome classes. The shaded region indicates the 95\% confidence interval under the null distribution, and the vertical pink line marks the observed difference. Bruchini (\textbf {A}) shows a significant enrichment of positively selected X-linked orthologs across all pairwise comparisons, whereas Coccinella (\textbf {B}) and Tribolium (\textbf {C}) show no significant difference. \relax }{figure.caption.27}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S3}{\ignorespaces Gene age categories of \textit  {C. maculatus} orthologs in the X chromosome and the autosomes. Percentages and absolute counts of genes in each ortholog age category are shown for pairwise comparisons between \textit  {C. maculatus} and \textit  {C. chinensis}, \textit  {B. siliquastri}, and \textit  {A. obtectus}. Age categories are defined relative to \textit  {C. maculatus} orthologs. Because evolutionary distance is measured from the \textit  {C. maculatus} lineage, the minimum detectable age category differs among comparisons, with \textit  {B. siliquastri} and \textit  {A. obtectus} comparisons starting at categories 1 and 2, respectively.\relax }}{}{table.caption.29}\protected@file@percent }
\newlabel{SItab:conservation}{{S3}{}{Gene age categories of \textit {C. maculatus} orthologs in the X chromosome and the autosomes. Percentages and absolute counts of genes in each ortholog age category are shown for pairwise comparisons between \textit {C. maculatus} and \textit {C. chinensis}, \textit {B. siliquastri}, and \textit {A. obtectus}. Age categories are defined relative to \textit {C. maculatus} orthologs. Because evolutionary distance is measured from the \textit {C. maculatus} lineage, the minimum detectable age category differs among comparisons, with \textit {B. siliquastri} and \textit {A. obtectus} comparisons starting at categories 1 and 2, respectively.\relax }{table.caption.29}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S4}{\ignorespaces Median regression results for the model \texttt  {dNdS $\sim $ chromosome + gene age}. The intercept corresponds to autosomal genes in the youngest gene-age category (age=1).\relax }}{}{table.caption.31}\protected@file@percent }
\newlabel{SItab:conservation}{{S4}{}{Median regression results for the model \texttt {dNdS $\sim $ chromosome + gene age}. The intercept corresponds to autosomal genes in the youngest gene-age category (age=1).\relax }{table.caption.31}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S12}{\ignorespaces Proportions of male-biased, female-biased, and unbiased genes among X-linked and autosomal loci in reproductive (abdominal) and somatic (head and thorax) tissues.\relax }}{}{figure.caption.32}\protected@file@percent }
\newlabel{SIfig:SB_prop}{{S12}{}{Proportions of male-biased, female-biased, and unbiased genes among X-linked and autosomal loci in reproductive (abdominal) and somatic (head and thorax) tissues.\relax }{figure.caption.32}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S13}{\ignorespaces Gene expression difference between the sexes, in the two tissue categories, across the X chromosome in C. maculatus. \relax }}{}{figure.caption.33}\protected@file@percent }
\newlabel{SIfig:dosagecompensation}{{S13}{}{Gene expression difference between the sexes, in the two tissue categories, across the X chromosome in C. maculatus. \relax }{figure.caption.33}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S5}{\ignorespaces Multinomial logistic regression of sex-bias category on the autosomes and the X chromosome as a function of gene age. The reference category is male-biased genes in gene-age category 1 (intercept).\relax }}{}{table.caption.34}\protected@file@percent }
\newlabel{SItab:mLogReg}{{S5}{}{Multinomial logistic regression of sex-bias category on the autosomes and the X chromosome as a function of gene age. The reference category is male-biased genes in gene-age category 1 (intercept).\relax }{table.caption.34}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S6}{\ignorespaces Median regression results for autosomal orthologs (model: \texttt  {log2FC $\sim $ sex-bias category * gene age}). The intercept corresponds to female-biased genes in gene-age category 1. The Wald test evaluates the joint significance of all two-way interaction terms.\relax }}{}{table.caption.35}\protected@file@percent }
\newlabel{SItab:A_logFCconservation}{{S6}{}{Median regression results for autosomal orthologs (model: \texttt {log2FC $\sim $ sex-bias category * gene age}). The intercept corresponds to female-biased genes in gene-age category 1. The Wald test evaluates the joint significance of all two-way interaction terms.\relax }{table.caption.35}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S7}{\ignorespaces Median regression results for X-linked orthologs (model: \texttt  {log2FC $\sim $ sex-bias category * gene age}). The intercept corresponds to female-biased genes in gene-age category 1. The Wald test evaluates the joint significance of all two-way interaction terms.\relax }}{}{table.caption.36}\protected@file@percent }
\newlabel{SItab:X_logFCconservation}{{S7}{}{Median regression results for X-linked orthologs (model: \texttt {log2FC $\sim $ sex-bias category * gene age}). The intercept corresponds to female-biased genes in gene-age category 1. The Wald test evaluates the joint significance of all two-way interaction terms.\relax }{table.caption.36}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S14}{\ignorespaces d$_N$/d$_S$ across gene age for male-biased (blue), unbiased (grey), and female-biased (red) autosomal genes of somatic tissues.\relax }}{}{figure.caption.37}\protected@file@percent }
