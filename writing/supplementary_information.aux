\@writefile{lot}{\contentsline {table}{\numberline {S2}{\ignorespaces \textbf  {d$_S$ permutation test}: Permutation test results for all pairwise species comparisons. Measured dS$_A$-dS$_X$, and estimated dS$_A$-dS$_X$ calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted dS$_A$-dS$_X$ values.\relax }}{}{table.caption.26}\protected@file@percent }
\newlabel{SItab:BUSCO}{{S2}{}{\textbf {d$_S$ permutation test}: Permutation test results for all pairwise species comparisons. Measured dS$_A$-dS$_X$, and estimated dS$_A$-dS$_X$ calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted dS$_A$-dS$_X$ values.\relax }{table.caption.26}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S3}{\ignorespaces \textbf  {d$_N$/d$_S$ permutation test}: Permutation test results for all pairwise species comparisons. Measured dN$_A$/dS$_A$-dN$_X$/dS$_X$, and estimated dN$_A$/dS$_A$-dN$_X$/dS$_X$ calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted dN$_A$/dS$_A$-dN$_X$/dS$_X$ values.\relax }}{}{table.caption.27}\protected@file@percent }
\newlabel{SItab:BUSCO}{{S3}{}{\textbf {d$_N$/d$_S$ permutation test}: Permutation test results for all pairwise species comparisons. Measured dN$_A$/dS$_A$-dN$_X$/dS$_X$, and estimated dN$_A$/dS$_A$-dN$_X$/dS$_X$ calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted dN$_A$/dS$_A$-dN$_X$/dS$_X$ values.\relax }{table.caption.27}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S4}{\ignorespaces Gene age categories of \textit  {C. maculatus} orthologs in the X chromosome and the autosomes. Percentages and absolute counts of genes in each ortholog age category are shown for pairwise comparisons between \textit  {C. maculatus} and \textit  {C. chinensis}, \textit  {B. siliquastri}, and \textit  {A. obtectus}. Age categories are defined relative to \textit  {C. maculatus} orthologs. and therefore the minimum detectable age category differs among comparisons, with \textit  {B. siliquastri} and \textit  {A. obtectus} comparisons starting at categories 2 and 3, respectively.\relax }}{}{table.caption.29}\protected@file@percent }
\newlabel{SItab:conservation}{{S4}{}{Gene age categories of \textit {C. maculatus} orthologs in the X chromosome and the autosomes. Percentages and absolute counts of genes in each ortholog age category are shown for pairwise comparisons between \textit {C. maculatus} and \textit {C. chinensis}, \textit {B. siliquastri}, and \textit {A. obtectus}. Age categories are defined relative to \textit {C. maculatus} orthologs. and therefore the minimum detectable age category differs among comparisons, with \textit {B. siliquastri} and \textit {A. obtectus} comparisons starting at categories 2 and 3, respectively.\relax }{table.caption.29}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S5}{\ignorespaces Median regression results for the model \texttt  {dNdS $\sim $ chromosome + gene age}. The intercept corresponds to autosomal genes in the youngest gene-age category (age=1). For \textit  {B. siliquastri}, The Wald-test for the chromosome by gene age interaction is significant, therefore the full model \texttt  {dNdS $\sim $ chromosome * gene age} is shown.\relax }}{}{table.caption.31}\protected@file@percent }
\newlabel{SItab:conservation}{{S5}{}{Median regression results for the model \texttt {dNdS $\sim $ chromosome + gene age}. The intercept corresponds to autosomal genes in the youngest gene-age category (age=1). For \textit {B. siliquastri}, The Wald-test for the chromosome by gene age interaction is significant, therefore the full model \texttt {dNdS $\sim $ chromosome * gene age} is shown.\relax }{table.caption.31}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S10}{\ignorespaces Proportions of male-biased, female-biased, and unbiased genes among X-linked and autosomal loci in reproductive (abdominal) and somatic (head and thorax) tissues.\relax }}{}{figure.caption.32}\protected@file@percent }
\newlabel{SIfig:SB_prop}{{S10}{}{Proportions of male-biased, female-biased, and unbiased genes among X-linked and autosomal loci in reproductive (abdominal) and somatic (head and thorax) tissues.\relax }{figure.caption.32}{}}
