\newlabel{SIfig:SB_prop}{{S10}{}{Proportions of male-biased, female-biased, and unbiased genes among X-linked and autosomal loci in reproductive (abdominal) and somatic (head and thorax) tissues.\relax }{figure.caption.32}{}}
