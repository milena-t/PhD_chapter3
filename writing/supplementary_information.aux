\@writefile{lot}{\contentsline {table}{\numberline {S7}{\ignorespaces Multinomial logistic regression of sex-bias category on the autosomes and the X chromosome as a function of gene age. The reference category is male-biased genes in gene-age category 1 (intercept).\relax }}{}{table.caption.34}\protected@file@percent }
\newlabel{SItab:mLogReg}{{S7}{}{Multinomial logistic regression of sex-bias category on the autosomes and the X chromosome as a function of gene age. The reference category is male-biased genes in gene-age category 1 (intercept).\relax }{table.caption.34}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S8}{\ignorespaces Median regression results for autosomal orthologs (model: \texttt  {log2FC $\sim $ sex-bias category * gene age}). The intercept corresponds to female-biased genes in gene-age category 1. The Wald test evaluates the joint significance of all two-way interaction terms.\relax }}{}{table.caption.35}\protected@file@percent }
\newlabel{SItab:A_logFCconservation}{{S8}{}{Median regression results for autosomal orthologs (model: \texttt {log2FC $\sim $ sex-bias category * gene age}). The intercept corresponds to female-biased genes in gene-age category 1. The Wald test evaluates the joint significance of all two-way interaction terms.\relax }{table.caption.35}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S9}{\ignorespaces Median regression results for X-linked orthologs (model: \texttt  {log2FC $\sim $ sex-bias category * gene age}). The intercept corresponds to female-biased genes in gene-age category 1. The Wald test evaluates the joint significance of all two-way interaction terms.\relax }}{}{table.caption.36}\protected@file@percent }
\newlabel{SItab:X_logFCconservation}{{S9}{}{Median regression results for X-linked orthologs (model: \texttt {log2FC $\sim $ sex-bias category * gene age}). The intercept corresponds to female-biased genes in gene-age category 1. The Wald test evaluates the joint significance of all two-way interaction terms.\relax }{table.caption.36}{}}
