\newlabel{SIfig:synteny_CmagCsep}{{S3}{}{Synteny plot of \textit {C. magnifica} (left) and \textit {C. septempunctata} (right), the X-chromosomes are mc64 for \textit {C. magnifica} and cs7 for \textit {C. septempunctata} (second from the bottom).\relax }{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S4}{\ignorespaces Synteny plot of \textit  {T. castaneum} (left) and \textit  {T. freemani} (right), the X-chromosomes are tc36 for \textit  {T. castaneum} and tf4 for \textit  {T. freemani} (first from the bottom).\relax }}{}{figure.caption.12}\protected@file@percent }
\newlabel{SIfig:synteny_TcasTfre}{{S4}{}{Synteny plot of \textit {T. castaneum} (left) and \textit {T. freemani} (right), the X-chromosomes are tc36 for \textit {T. castaneum} and tf4 for \textit {T. freemani} (first from the bottom).\relax }{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S5}{\ignorespaces Synteny plot of \textit  {B. siliquastri} (right) and \textit  {T. castaneum} (right), the X-chromosomes are bs9 for \textit  {B. siliquastri} and tc36 for \textit  {T. castaneum} (third and second from the bottom).\relax }}{}{figure.caption.14}\protected@file@percent }
\newlabel{SIfig:synteny_TcasBsil}{{S5}{}{Synteny plot of \textit {B. siliquastri} (right) and \textit {T. castaneum} (right), the X-chromosomes are bs9 for \textit {B. siliquastri} and tc36 for \textit {T. castaneum} (third and second from the bottom).\relax }{figure.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S6}{\ignorespaces \textbf  {d$_S$ vs. d$_N$ scatterplots and violin plots of d$_S$ values from X-linked and autosomal orthologs.} Pairwise comparisons between members of three lineages with violin plots of d$_S$ values for X-linked and autosomal 1-to-1 orthologs, and scatterplots of d$_S$ vs. d$_N$. Permutation tests (n=10000) show that d$_S$ is significantly lower for X-linked orthologs in all comparisons within \textit  {Bruchini} (\textbf  {A}) and \textit  {Coccinella} (\textbf  {B}), but not \textit  {Tribolium} (\textbf  {C}). \relax }}{}{figure.caption.16}\protected@file@percent }
\newlabel{dS_plots}{{S6}{}{\textbf {d$_S$ vs. d$_N$ scatterplots and violin plots of d$_S$ values from X-linked and autosomal orthologs.} Pairwise comparisons between members of three lineages with violin plots of d$_S$ values for X-linked and autosomal 1-to-1 orthologs, and scatterplots of d$_S$ vs. d$_N$. Permutation tests (n=10000) show that d$_S$ is significantly lower for X-linked orthologs in all comparisons within \textit {Bruchini} (\textbf {A}) and \textit {Coccinella} (\textbf {B}), but not \textit {Tribolium} (\textbf {C}). \relax }{figure.caption.16}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S2}{\ignorespaces Permutation test results for all pairwise species comparisons. Estimated dS$_A$-dS$_X$ calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted dS$_A$-dS$_X$ values.\relax }}{}{table.caption.18}\protected@file@percent }
\newlabel{SItab:BUSCO}{{S2}{}{Permutation test results for all pairwise species comparisons. Estimated dS$_A$-dS$_X$ calculated from mean of 10000 permutations, 95\% Confidence interval (CI) calculated from normal distribution of permuted dS$_A$-dS$_X$ values.\relax }{table.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S7}{\ignorespaces \textbf  {d$_N$/d$_S$ ratio and permutation tests for significance.} Pairwise comparisons between members of three species groups with violin plots of d$_N$/d$_S$ values for X-linked and autosomal 1-to-1 orthologs, and permutation tests (10000 permutations) to assess significance. The permutation test show frequency histograms of median differences between autosomal and X-linked d$_N$/d$_S$, with the shaded area showing the 95\% confidence interval according to a normal distribution. The vertical pink line shows the true observed difference in mean between autosomal and X-linked d$_N$/d$_S$. All pairwise comparisons show significantly lower d$_N$/d$_S$ values on X-linked orthologs. The within-family comparisons are performed for three species groups: \textit  {Bruchini} (\textbf  {A}), \textit  {Coccinella} (\textbf  {B}) and \textit  {Tribolium} (\textbf  {C}). \relax }}{}{figure.caption.19}\protected@file@percent }
\newlabel{dNdS_ratios}{{S7}{}{\textbf {d$_N$/d$_S$ ratio and permutation tests for significance.} Pairwise comparisons between members of three species groups with violin plots of d$_N$/d$_S$ values for X-linked and autosomal 1-to-1 orthologs, and permutation tests (10000 permutations) to assess significance. The permutation test show frequency histograms of median differences between autosomal and X-linked d$_N$/d$_S$, with the shaded area showing the 95\% confidence interval according to a normal distribution. The vertical pink line shows the true observed difference in mean between autosomal and X-linked d$_N$/d$_S$. All pairwise comparisons show significantly lower d$_N$/d$_S$ values on X-linked orthologs. The within-family comparisons are performed for three species groups: \textit {Bruchini} (\textbf {A}), \textit {Coccinella} (\textbf {B}) and \textit {Tribolium} (\textbf {C}). \relax }{figure.caption.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S8}{\ignorespaces \textbf  {positively selected orthologs split into autosomal or X-linked.} Positively selected genes are determined via likelihood ratio test comparison between paml site models M1a and M2a. The permutation tests show frequency histograms of median differences between the percentage of orthologs for 10000 permutations with positively selected codons between autosomal and X-linked orthologs, with the shaded area showing the 95\% confidence interval according to a normal distribution. The vertical pink line shows the true observed difference in percentage of orthologs with positively selected codons between autosomal and X-linked orthologs. \textit  {Bruchini} (\textbf  {A}), show an enrichment of positively selected X-linked orthologs in all pairwise comparisons, while \textit  {Coccinella} (\textbf  {B}) and \textit  {Tribolium} (\textbf  {C}) show no significant difference. \relax }}{}{figure.caption.20}\protected@file@percent }
\newlabel{site_models}{{S8}{}{\textbf {positively selected orthologs split into autosomal or X-linked.} Positively selected genes are determined via likelihood ratio test comparison between paml site models M1a and M2a. The permutation tests show frequency histograms of median differences between the percentage of orthologs for 10000 permutations with positively selected codons between autosomal and X-linked orthologs, with the shaded area showing the 95\% confidence interval according to a normal distribution. The vertical pink line shows the true observed difference in percentage of orthologs with positively selected codons between autosomal and X-linked orthologs. \textit {Bruchini} (\textbf {A}), show an enrichment of positively selected X-linked orthologs in all pairwise comparisons, while \textit {Coccinella} (\textbf {B}) and \textit {Tribolium} (\textbf {C}) show no significant difference. \relax }{figure.caption.20}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S3}{\ignorespaces Percentages of each gene age category from the perspective of \textit  {C. maculatus} in pairwise comparisons to \textit  {C. chinensis}, \textit  {B. siliquastri}, and \textit  {A. obtectus}. Percentages and absolute counts are shown. Since the distance is determined from the perspective of \textit  {C. maculatus} orthologs, the \textit  {B. siliqastri} and \textit  {A. obtectus} comparisons can have a minimum distance category of 1 and 2 respectively.\relax }}{}{table.caption.22}\protected@file@percent }
\newlabel{SItab:conservation}{{S3}{}{Percentages of each gene age category from the perspective of \textit {C. maculatus} in pairwise comparisons to \textit {C. chinensis}, \textit {B. siliquastri}, and \textit {A. obtectus}. Percentages and absolute counts are shown. Since the distance is determined from the perspective of \textit {C. maculatus} orthologs, the \textit {B. siliqastri} and \textit {A. obtectus} comparisons can have a minimum distance category of 1 and 2 respectively.\relax }{table.caption.22}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S4}{\ignorespaces Median regression results of \texttt  {dNdS $\sim $ chromosome + gene age}. The intercept is autosomal genes of gene age 1.\relax }}{}{table.caption.24}\protected@file@percent }
\newlabel{SItab:conservation}{{S4}{}{Median regression results of \texttt {dNdS $\sim $ chromosome + gene age}. The intercept is autosomal genes of gene age 1.\relax }{table.caption.24}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S5}{\ignorespaces Logistic regression results of \texttt  {pos. sel. $\sim $ chromosome + gene age}. The intercept is autosomal genes of gene age 1. The positive coefficients indicate that the X-chromosome is enriched for genes under positive selection.\relax }}{}{table.caption.26}\protected@file@percent }
\newlabel{SItab:conservation}{{S5}{}{Logistic regression results of \texttt {pos. sel. $\sim $ chromosome + gene age}. The intercept is autosomal genes of gene age 1. The positive coefficients indicate that the X-chromosome is enriched for genes under positive selection.\relax }{table.caption.26}{}}
