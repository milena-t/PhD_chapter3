\@writefile{lot}{\contentsline {table}{\numberline {S6}{\ignorespaces Median regression results for autosomal orthologs (model: \texttt  {log2FC $\sim $ sex-bias category * gene age}). The intercept corresponds to female-biased genes in gene-age category 1. The Wald test evaluates the joint significance of all two-way interaction terms.\relax }}{}{table.caption.34}\protected@file@percent }
\newlabel{SItab:A_logFCconservation}{{S6}{}{Median regression results for autosomal orthologs (model: \texttt {log2FC $\sim $ sex-bias category * gene age}). The intercept corresponds to female-biased genes in gene-age category 1. The Wald test evaluates the joint significance of all two-way interaction terms.\relax }{table.caption.34}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S7}{\ignorespaces Median regression results for X-linked orthologs (model: \texttt  {log2FC $\sim $ sex-bias category * gene age}). The intercept corresponds to female-biased genes in gene-age category 1. The Wald test evaluates the joint significance of all two-way interaction terms.\relax }}{}{table.caption.35}\protected@file@percent }
\newlabel{SItab:X_logFCconservation}{{S7}{}{Median regression results for X-linked orthologs (model: \texttt {log2FC $\sim $ sex-bias category * gene age}). The intercept corresponds to female-biased genes in gene-age category 1. The Wald test evaluates the joint significance of all two-way interaction terms.\relax }{table.caption.35}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S12}{\ignorespaces d$_N$/d$_S$ across gene age for male-biased (blue), unbiased (grey), and female-biased (red) autosomal genes of somatic tissues.\relax }}{}{figure.caption.36}\protected@file@percent }
\newlabel{SIfig:SBmag_a}{{S12}{}{d$_N$/d$_S$ across gene age for male-biased (blue), unbiased (grey), and female-biased (red) autosomal genes of somatic tissues.\relax }{figure.caption.36}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S13}{\ignorespaces d$_N$/d$_S$ across gene age for male-biased (blue), unbiased (grey), and female-biased (red) X-linked genes of somatic tissues.\relax }}{}{figure.caption.37}\protected@file@percent }
\newlabel{SIfig:SBmag_ht}{{S13}{}{d$_N$/d$_S$ across gene age for male-biased (blue), unbiased (grey), and female-biased (red) X-linked genes of somatic tissues.\relax }{figure.caption.37}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S8}{\ignorespaces Detailed results from Fisher's exact test to test for Faster-X restricted to female- male- or unbiased orthologs. Shows the contingency tables with numbers of positively selected (pos. sel.) and not pos. sel. orthologs linked to autosomes (A) or X. Sex bias is determined from reproductive tissues (abdomen) or somatic tissues (head $+$ thorax).  Note that the numbers do not add up with Fig. \ref  {SIfig:SB_prop}, since the process of estimating codons under postive selection removes genes from the data due to the requirement to be 1-to-1 orthologs, incorrect start/stop codons, or other issues that make running paml impossible.\relax }}{}{table.caption.38}\protected@file@percent }
\newlabel{SITab:fisher-pos_sel}{{S8}{}{Detailed results from Fisher's exact test to test for Faster-X restricted to female- male- or unbiased orthologs. Shows the contingency tables with numbers of positively selected (pos. sel.) and not pos. sel. orthologs linked to autosomes (A) or X. Sex bias is determined from reproductive tissues (abdomen) or somatic tissues (head $+$ thorax).\\ Note that the numbers do not add up with Fig. \ref {SIfig:SB_prop}, since the process of estimating codons under postive selection removes genes from the data due to the requirement to be 1-to-1 orthologs, incorrect start/stop codons, or other issues that make running paml impossible.\relax }{table.caption.38}{}}
