\newlabel{SItab:mLogReg}{{S6}{}{Multinomial logistic regression of sex-bias categories by gene age. Due to very low sample size for the X-linked orthologs, the analysis was only performed for autosomal orthologs. The intercept is male-bias and conservaiton distance 1.\relax }{table.caption.31}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S7}{\ignorespaces Median regression results of autosomal orthologs: \texttt  {log2FC $\sim $ sex-bias category * gene age}. The intercept is female-biased genes of gene age 1, the wald-test is performed for all two-way interactions at once.\relax }}{}{table.caption.32}\protected@file@percent }
\newlabel{SItab:A_logFCconservation}{{S7}{}{Median regression results of autosomal orthologs: \texttt {log2FC $\sim $ sex-bias category * gene age}. The intercept is female-biased genes of gene age 1, the wald-test is performed for all two-way interactions at once.\relax }{table.caption.32}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S8}{\ignorespaces Median regression results of X-linked orthologs: \texttt  {log2FC $\sim $ sex-bias category * gene age}. The intercept is female-biased genes of gene age 1, the wald-test is performed for all two-way interactions at once.\relax }}{}{table.caption.33}\protected@file@percent }
\newlabel{SItab:X_logFCconservation}{{S8}{}{Median regression results of X-linked orthologs: \texttt {log2FC $\sim $ sex-bias category * gene age}. The intercept is female-biased genes of gene age 1, the wald-test is performed for all two-way interactions at once.\relax }{table.caption.33}{}}
